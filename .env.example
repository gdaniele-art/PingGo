POSTGRES_USER=pinggo
POSTGRES_PASSWORD=pinggo_dev_password
POSTGRES_DB=pinggo

# You need to generate a random key for encryption.
N8N_ENCRYPTION_KEY=change-me-change-me-change-me-123456

# =========================
# Alerts - Backend to n8n
# =========================

# Enable or disable alert notifications from the Spring Boot backend to n8n.
ALERTS_ENABLED=true

# Production webhook URL used by active n8n workflows.
# Inside Docker, use the service name "n8n" instead of "localhost".
ALERTS_N8N_WEBHOOK_URL=http://n8n:5678/webhook/pinggo-alerts


# Test webhook URL used while manually testing the workflow in the n8n editor.
# Use this only when the n8n workflow is in test mode.
# ALERTS_N8N_WEBHOOK_URL=http://n8n:5678/webhook-test/pinggo-alerts
